import re

def _create_tar_input_list():
  fd, path = tempfile.mkstemp(prefix="iceshelf-tar.")
  sent_filenames = []
  by_path = {}
  try:
    with os.fdopen(fd, "wb") as fp:
      for filename in newFiles:
        if filename in movedFiles:
          continue
        fp.write(os.fsencode(filename))
        fp.write(b"\0")
        sent_filenames.append(filename)
        by_path.setdefault(os.path.normpath(filename), []).append(filename)
  except Exception:
    try:
      os.unlink(path)
    except OSError:
      pass
    raise
  return path, sent_filenames, by_path


def _first_stderr_line(stderr_text):
  for line in stderr_text.splitlines():
    line = line.strip()
    if line:
      return line
  return None


def _log_stage_stderr(stage_name, stderr_text, failed):
  for line in stderr_text.splitlines():
    line = line.strip()
    if not line:
      continue

    if stage_name == "tar" and "Removing leading `/'" in line:
      logging.debug("tar: %s", line)
      continue

    if stage_name == "tar" and (
      "Cannot stat" in line or
      "Cannot open" in line or
      "File removed before we read it" in line
    ):
      logging.warning("tar: %s", line)
      continue

    if failed:
      logging.error("%s: %s", stage_name, line)
    else:
      logging.debug("%s: %s", stage_name, line)


def _remove_partial_output(path):
  if not path or not os.path.exists(path):
    return

  try:
    os.remove(path)
  except OSError as exc:
    logging.warning("Unable to remove partial archive \"%s\": %s", path, exc)


def _run_stream_pipeline(stages, output_path):
  processes = []
  output_handle = None
  current_stage = None
  stage_results = []

  try:
    output_handle = open(output_path, "wb")
    previous_stdout = None

    for index, stage in enumerate(stages):
      current_stage = stage
      stdout = output_handle if index == len(stages) - 1 else PIPE
      proc = Popen(
        stage["cmd"],
        stdin=previous_stdout,
        stdout=stdout,
        stderr=PIPE,
        env=stage.get("env"),
      )
      processes.append((stage, proc))
      if previous_stdout is not None:
        previous_stdout.close()
      previous_stdout = proc.stdout if stdout == PIPE else None

    output_handle.close()
    output_handle = None
  except OSError as exc:
    if output_handle is not None:
      output_handle.close()
    for _stage, proc in processes:
      proc.kill()
      proc.wait()
    stage_name = current_stage["name"] if current_stage is not None else "output"
    logging.error("Unable to start archive pipeline stage \"%s\": %s", stage_name, exc)
    return False, stage_results

  success = True
  first_failure = None
  for stage, proc in processes:
    returncode = proc.wait()
    stderr_text = proc.stderr.read().decode("utf-8", errors="replace").strip()
    stage_results.append({
      "name": stage["name"],
      "returncode": returncode,
      "stderr": stderr_text,
    })
    failed = returncode != 0
    _log_stage_stderr(stage["name"], stderr_text, failed)
    if failed and success:
      first_failure = (stage["name"], _first_stderr_line(stderr_text), returncode)
      success = False

  if not success and first_failure is not None:
    stage_name, stderr_line, returncode = first_failure
    message = stderr_line or "command exited with code %d" % returncode
    logging.error("Archive pipeline stage \"%s\" failed: %s", stage_name, message)

  return success, stage_results


_TAR_UNAVAILABLE_PATTERNS = (
  re.compile(r"^[^:]+: (?P<path>.*): Warning: Cannot stat: (?P<reason>.*)$"),
  re.compile(r"^[^:]+: (?P<path>.*): Cannot open: (?P<reason>.*)$"),
  re.compile(r"^[^:]+: (?P<path>.*): File removed before we read it$"),
)


def _parse_tar_unavailable_entries(stderr_text):
  entries = []
  for raw_line in stderr_text.splitlines():
    line = raw_line.strip()
    if not line or "Removing leading `/'" in line:
      continue

    for pattern in _TAR_UNAVAILABLE_PATTERNS:
      match = pattern.match(line)
      if match is None:
        continue
      entries.append({
        "path": os.path.normpath(match.group("path")),
        "reason": match.groupdict().get("reason") or "File removed before we read it",
      })
      break
  return entries


def _match_unreconciled_entry(entry, by_path, sent_filenames):
  entry_path = entry["path"]

  for filename in sent_filenames:
    if filename == entry_path:
      return filename

  candidate_normpaths = set()
  entry_sep = entry_path + os.sep
  for norm, originals in by_path.items():
    norm_sep = norm + os.sep
    if norm.endswith(entry_sep) or entry_path.endswith(norm_sep):
      candidate_normpaths.add(norm)
      continue
    if norm.endswith(os.sep + entry_path) or entry_path.endswith(os.sep + norm):
      candidate_normpaths.add(norm)

  if len(candidate_normpaths) == 1:
    norm = next(iter(candidate_normpaths))
    originals = by_path.get(norm, [])
    if len(originals) == 1:
      return originals[0]

  return None


def _drop_newfile(filename, reason, unreconciled_resolved=False):
  details = currentFileDetails.pop(filename, None)
  if details is not None:
    currentOp["filecount"] = max(currentOp["filecount"] - 1, 0)
    currentOp["filesize"] = max(currentOp["filesize"] - details["size"], 0)
    if details["compressable"]:
      currentOp["compressable"] = max(currentOp["compressable"] - details["size"], 0)

  newFiles.pop(filename, None)
  return {
    "path": filename,
    "reason": reason,
    "unreconciled_resolved": unreconciled_resolved,
  }


def _prune_unavailable_files(entries, by_path, sent_filenames, tolerate=False):
  removed = []
  unresolved = []

  for entry in entries:
    matches = by_path.get(entry["path"], [])
    matched_any = False
    for filename in matches:
      if filename not in newFiles:
        continue
      removed.append(_drop_newfile(filename, entry["reason"]))
      matched_any = True

    if matched_any:
      continue

    if tolerate:
      resolved = _match_unreconciled_entry(entry, by_path, sent_filenames)
      if resolved is not None and resolved in newFiles:
        removed.append(_drop_newfile(resolved, entry["reason"], unreconciled_resolved=True))
        continue

    unresolved.append(entry)

  return removed, unresolved


def _log_unavailable_file_summary(entries, mode):
  if not entries:
    return

  if mode == "ignored":
    logging.warning("Skipping %d unavailable file(s) during archive creation", len(entries))
    for entry in entries:
      logging.warning('Archive skipped "%s": %s', entry["path"], entry["reason"])
    return

  if mode == "tolerated":
    logging.warning(
      "Archive proceeded despite %d unreconcilable unavailable file(s); "
      "state left unchanged for these paths. Re-run the backup until no such warnings appear.",
      len(entries))
    for entry in entries:
      logging.warning('Archive tolerated unreconcilable "%s": %s', entry["path"], entry["reason"])
    return

  logging.error("Archive creation encountered %d unavailable file(s)", len(entries))
  for entry in entries:
    logging.error('Archive could not read "%s": %s', entry["path"], entry["reason"])


def _select_archive_compressor():
  if not config["compress"] or currentOp["filesize"] <= 0:
    return None

  if not config["compress-force"] and not shouldCompress():
    logging.info(
      "Content is not likely to compress (%d%% chance), skipping compression.",
      compressionChance())
    return None

  compressor = fileutils.select_bzip2_compressor(configuration.which)
  if compressor is None:
    logging.error("Compression was requested, but no bzip2-compatible compressor was found")
    return None

  return compressor


def create_archive(base):
  archive = base + ".tar"
  compressor = _select_archive_compressor()
  if config["compress"] and currentOp["filesize"] > 0 and (config["compress-force"] or shouldCompress()):
    if compressor is None:
      return None
    archive += ".bz2"

  if config["encrypt"]:
    archive += ".gpg"
  if config["sign"]:
    archive += ".sig"

  tar_cmd = configuration.which("tar")
  if tar_cmd is None:
    logging.error("Unable to create archive, tar is not installed")
    return None

  tar_input = None
  passphrase_files = []
  try:
    tar_input, sent_filenames, tar_by_path = _create_tar_input_list()
    stages = [{
      "name": "tar",
      "cmd": [
        tar_cmd,
        "--create",
        "--file", "-",
        "--dereference",
        "--null",
        "--files-from", tar_input,
        "--ignore-failed-read",
      ],
    }]

    if compressor is not None:
      compressor_name = os.path.basename(compressor)
      if compressor_name != "bzip2":
        logging.info("Using %s for compression", compressor_name)
      stages.append({
        "name": compressor_name,
        "cmd": [compressor, "-c"],
      })

    if config["encrypt"]:
      encrypt_cmd, encrypt_env, encrypt_passphrase = gpg_module.build_stream_encrypt_command(
        config["encrypt"], keyring_dir, passphrase=config["encrypt-pw"], armor=False)
      passphrase_files.append(encrypt_passphrase)
      stages.append({
        "name": "gpg encrypt",
        "cmd": encrypt_cmd,
        "env": encrypt_env,
      })

    if config["sign"]:
      sign_cmd, sign_env, sign_passphrase = gpg_module.build_stream_sign_command(
        config["sign"], keyring_dir, passphrase=config["sign-pw"], binary=True)
      passphrase_files.append(sign_passphrase)
      stages.append({
        "name": "gpg sign",
        "cmd": sign_cmd,
        "env": sign_env,
      })

    logging.info(
      "Preparing content for archiving, may take quite a while depending on size")
    success, stage_results = _run_stream_pipeline(stages, archive)

    tar_result = None
    for stage_result in stage_results:
      if stage_result["name"] == "tar":
        tar_result = stage_result
        break

    unavailable_entries = []
    if tar_result is not None:
      unavailable_entries = _parse_tar_unavailable_entries(tar_result["stderr"])

    if unavailable_entries:
      if config["ignore-unavailable-files"]:
        tolerate = config["tolerate-unreconcilable-files"]
        removed_entries, unresolved_entries = _prune_unavailable_files(
          unavailable_entries, tar_by_path, sent_filenames, tolerate=tolerate)

        if unresolved_entries and not tolerate:
          logging.error("Archive reported unavailable files that could not be reconciled with the scan state")
          _log_unavailable_file_summary(unavailable_entries, mode="error")
          _remove_partial_output(archive)
          return None

        if removed_entries:
          _log_unavailable_file_summary(removed_entries, mode="ignored")
        if unresolved_entries:
          _log_unavailable_file_summary(unresolved_entries, mode="tolerated")
      else:
        _log_unavailable_file_summary(unavailable_entries, mode="error")
        _remove_partial_output(archive)
        return None

    if not success:
      _remove_partial_output(archive)
      return None

    return archive
  finally:
    if tar_input is not None:
      try:
        os.unlink(tar_input)
      except OSError:
        pass
    for passphrase_file in passphrase_files:
      gpg_module.cleanup_passphrase_file(passphrase_file)


def create_manifest(path):
  tmp1 = {}
  tmp2 = []
  for k, v in newFiles.items():
    if k not in movedFiles:
      tmp1[k] = v
  for k in deletedFiles:
    if k not in movedFiles.values():
      tmp2.append(k)
  manifest = {
    "modified": tmp1,
    "deleted": tmp2,
    "moved": movedFiles,
    "previousbackup": lastBackup,
  }
  with open(path, "w", encoding="utf-8") as fp:
    fp.write(json.dumps(manifest, ensure_ascii=False))
  return path


def encrypt_file(path, armor=False):
  outpath = path + ".gpg"
  ok, stderr = gpg_module.gpg_encrypt_file(
    path, outpath, config["encrypt"], keyring_dir,
    passphrase=config["encrypt-pw"], armor=armor)
  if not ok or not os.path.exists(outpath):
    logging.error("GnuPG encryption failed: %s", stderr)
    return None
  os.remove(path)
  return outpath


def sign_file(path, binary=False):
  outfile = path + (".sig" if binary else ".asc")
  ok, stderr = gpg_module.gpg_sign_file(
    path, outfile, config["sign"], keyring_dir,
    passphrase=config["sign-pw"], binary=binary)
  if not ok or not os.path.exists(outfile):
    logging.error("GnuPG signing failed: %s", stderr)
    return None
  os.remove(path)
  return outfile


def add_parity(path):
  logging.info("Generating %d%% parity information", config['parity'])
  return fileutils.generateParity(path, config["parity"])


def _prepared_file_priority(filename):
  if ".activity.log.bz2" in filename:
    return 0
  if ".tar" in filename and ".par2" not in filename:
    return 1
  if ".json" in filename:
    return 2
  if ".par2" in filename:
    return 3
  if ".lst" in filename:
    return 4
  return 5


def _prepared_files():
  return sorted(
    os.listdir(config["prepdir"]),
    key=lambda name: (_prepared_file_priority(name), name),
  )


def create_activity_log_artifact(base):
  if log_session is None:
    logging.error("Unable to create activity log artifact without an active logging session")
    return None

  source_path = log_session.artifact_source_path
  if not source_path:
    logging.error("Unable to create activity log artifact because no logfile source exists")
    return None

  snapshot_path = base + ".activity.log"
  compressed_path = snapshot_path + ".bz2"
  try:
    log_session.snapshot(snapshot_path)
  except (OSError, ValueError) as exc:
    logging.error("Unable to snapshot activity log: %s", exc)
    return None

  compressor = fileutils.select_bzip2_compressor(configuration.which)
  if compressor is None:
    logging.error("Activity log upload requires a bzip2-compatible compressor, but none was found")
    try:
      os.unlink(snapshot_path)
    except OSError:
      pass
    return None

  if not fileutils.compress_with_bzip2(snapshot_path, compressed_path, compressor=compressor):
    try:
      os.unlink(snapshot_path)
    except OSError:
      pass
    logging.error("Unable to compress activity log artifact")
    return None

  os.unlink(snapshot_path)
  artifact_path = compressed_path

  if config["encrypt"]:
    artifact_path = encrypt_file(artifact_path)
    if artifact_path is None:
      return None

  if config["sign"]:
    artifact_path = sign_file(artifact_path)
    if artifact_path is None:
      return None

  return artifact_path


def gatherData():
  base = os.path.join(config["prepdir"], config["prefix"] + config["unique"])
  file_archive = None
  file_manifest = base + ".json"
  file_activity_log = None

  havearchive = False
  if len(newFiles) - len(movedFiles):
    file_archive = create_archive(base)
    if file_archive is None:
      return None
    if len(newFiles) - len(movedFiles) == 0:
      _remove_partial_output(file_archive)
      file_archive = None
    else:
      havearchive = True
  else:
    if len(movedFiles):
      logging.info("No files to save, only metadata changes, skipping archive")
    else:
      logging.info("No files to save, skipping archive")

  if len(newFiles) == 0 and len(deletedFiles) == 0:
    logging.info("All archive candidates became unavailable, skipping backup")
    return []

  if config["manifest"]:
    file_manifest = create_manifest(file_manifest)

  if havearchive and config["parity"] > 0:
    if not add_parity(file_archive):
      logging.error("Unable to create PAR2 file for this archive")
      return None

  if config["encrypt"] and config["encrypt-manifest"] and config["manifest"]:
    file_manifest = encrypt_file(file_manifest, armor=True)
    if file_manifest is None:
      return None

  if config["sign"]:
    if config["manifest"]:
      file_manifest = sign_file(file_manifest)
      if file_manifest is None:
        return None
    if config["parity"] > 0:
      logging.info("Signing parity")
      for f in os.listdir(config["prepdir"]):
        if f.endswith('.par2'):
          f = os.path.join(config["prepdir"], f)
          signed = sign_file(f, binary=True)
          if signed is None:
            return None

  if config["upload-activity-log"]:
    file_activity_log = create_activity_log_artifact(base)
    if file_activity_log is None:
      return None

  if config["create-filelist"]:
    file_list = base + ".lst"
    fileutils.generateFilelist(config["prepdir"], file_list)
    if config["sign"]:
      signed = sign_file(file_list)
      if signed is None:
        return None

  return _prepared_files()
