    # Set ultimate trust on imported keys so GPG can verify signatures (not just decrypt).
    def _keyring_fingerprints(keyring_dir):
        """Get primary key fingerprints from keyring via gpg --list-keys --with-colons."""
        try:
            result = subprocess.run(
                ['gpg', '--no-tty', '--batch', '--list-keys', '--with-colons'],
                env=dict(os.environ, GNUPGHOME=keyring_dir),
                capture_output=True,
                text=True,
                timeout=10,
            )
            if result.returncode != 0:
                return []
            fingerprints = []
            want_next_fpr = False
            for line in (result.stdout or '').splitlines():
                # Only fpr immediately after pub: or sec: (primary key), not after sub:
                if line.startswith('pub:') or line.startswith('sec:'):
                    want_next_fpr = True
                    continue
                if line.startswith('fpr:'):
                    if want_next_fpr:
                        parts = line.split(':')
                        if len(parts) >= 10 and parts[9]:
                            fingerprints.append(parts[9])
                    want_next_fpr = False
            return fingerprints
        except (OSError, subprocess.TimeoutExpired):
            return []

    fingerprints = getattr(import_result, 'fingerprints', None) or []
    if not fingerprints:
        fingerprints = _keyring_fingerprints(temp_keyring_dir)
    if fingerprints:
