def secure_wipe_temp_dir(temp_dir):
    """
    Securely wipe a temporary keyring directory: overwrite files with zeros
    then remove. No key material should remain on disk.
    """
    if not temp_dir or not os.path.isdir(temp_dir):
        return
    for dirpath, dirnames, filenames in os.walk(temp_dir, topdown=False):
        for name in filenames:
            path = os.path.join(dirpath, name)
            try:
                if os.path.isfile(path) and not os.path.islink(path):
                    with open(path, 'r+b') as f:
                        length = f.seek(0, 2)
                        f.seek(0)
                        f.write(b'\x00' * length)
                os.unlink(path)
            except OSError as exc:
                logging.warning(
                    'Secure wipe failed for "%s": %s; removing anyway', path, exc)
                try:
                    os.unlink(path)
                except OSError:
                    pass
        for name in dirnames:
            path = os.path.join(dirpath, name)
            try:
                os.rmdir(path)
            except OSError as exc:
                logging.warning('Failed to remove directory "%s": %s', path, exc)
    try:
        os.rmdir(temp_dir)
    except OSError as exc:
        logging.warning(
            'Secure wipe: could not remove temp keyring dir "%s": %s. '
            'You may want to remove it manually (e.g. shred).', temp_dir, exc)


