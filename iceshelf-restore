                    except (AttributeError, TypeError, ValueError):
                        pass
        # Always run --import-ownertrust: trust_keys may not exist or may not affect gpg binary.
        try:
            ownertrust = ''.join('%s:6:\n' % f for f in fingerprints if f)
            if ownertrust:
