                if manifest_key not in manifest['modified'] and manifest_key not in manifest.get('moved', {}):
                    logging.error(
                        'Archive contains "%s", not listed in the manifest',
                        item.name)
                    fileerror += 1
                elif manifest_key in manifest['modified']:
                    manifest['modified'][manifest_key]['found'] = True
                    filecount -= 1
                # moved entries: do not treat as unlisted; nothing to extract
                item = tar.next()
        sys.stderr.write('\n')
        sys.stderr.flush()

        # Check that all files we were looking for was in the archive
        for k in manifest['modified']:
            if 'found' not in manifest['modified'][k]:
                logging.error('Archive is missing "%s"', k)
                restore_outcome_single[k] = 'skipped'
                skip_reasons_single[k] = 'not in archive'
                restore_failed_single = True

        if fileerror != 0:
            restore_failed_single = True

    # Step 1: Remove any files that were deleted
    for f in manifest['deleted']:
        src = os.path.normpath(restore_base + f)
        if cmdline.list:
            logging.info('Manifest: Deleting "%s"', src)
        if cmdline.restore:
            try:
                os.unlink(src)
            except OSError as e:
                logging.warning('Unable to remove "%s": %s', src, e)

    for k in manifest['moved']:
        v = _normalize_moved_entry(manifest['moved'][k], basename)
        src = os.path.normpath(restore_base + v.get('original', ''))
        dst = os.path.normpath(restore_base + k)
        if cmdline.list:
            logging.info('Manifest: Moving "%s" to "%s"', src, dst)
        if cmdline.restore and os.path.exists(src):
            try:
                os.rename(src, dst)
            except OSError as e:
                logging.warning('Unable to move "%s" to "%s": %s', src, dst, e)

    # Finally, if not a dryrun
    if not cmdline.restore:
        sys.exit(0)

    # Time to extract the files (with conflict check before each)
    conflict_mode = cmdline.conflict
    verbose = getattr(cmdline, 'verbose', False)
    total_files = len(manifest.get('modified', {}))
    processed = 0

    # Resumable restore: apply completed.lst (size match -> skip; mismatch -> remove file for re-restore)
    completed_lst_path = _completed_lst_path(restore_base, cmdline)
    verified_single = _apply_completed_lst(
        restore_base, completed_lst_path, merged_single.keys(),
        restore_outcome_single, skip_reasons_single)
    pre_skipped_paths_single = set(verified_single)

    # Preemptive skip: check destination before opening tar (same logic as multi-archive)
    if conflict_mode == 'skipsame':
        modified_list = list(manifest.get('modified', {}).items())
        total_to_check = len(modified_list)
        sys.stderr.write('Locating already restored files\n')
        sys.stderr.flush()
        for idx, (path, meta) in enumerate(modified_list, 1):
            path = _norm_path(path)
            dest_full = os.path.normpath(restore_base + path)
            checksum = meta.get('checksum', '')
            pct_overall = 100 * idx // total_to_check if total_to_check else 0
            if path in pre_skipped_paths_single:
                sys.stderr.write(
                    '\rChecking file %d of %d (%d%%): skipped (completed).    '
                    % (idx, total_to_check, pct_overall))
                sys.stderr.flush()
                continue
            if not os.path.isfile(dest_full):
                sys.stderr.write(
                    '\rChecking file %d of %d (%d%%): not present.    '
                    % (idx, total_to_check, pct_overall))
                sys.stderr.flush()
            else:
                def _hash_progress(bytes_done, total):
                    pct_file = 100 * bytes_done // total if total else 0
                    sys.stderr.write(
                        '\rChecking file %d of %d (%d%%): Calculating, %d%% done.    '
                        % (idx, total_to_check, pct_overall, pct_file))
                    sys.stderr.flush()
                if _dest_has_same_checksum(dest_full, checksum, progress_callback=_hash_progress):
                    pre_skipped_paths_single.add(path)
                    restore_outcome_single[path] = 'skipped'
                    skip_reasons_single[path] = 'already existed, same content (--conflict skipsame)'
                    if os.path.isfile(dest_full):
                        _append_completed_lst(completed_lst_path, path, os.path.getsize(dest_full))
        if modified_list:
            sys.stderr.write('\n')
            sys.stderr.flush()
            n_found = len(pre_skipped_paths_single)
            pct_found = 100 * n_found // total_to_check if total_to_check else 0
            sys.stderr.write('Found %d of %d (%d%%). %d to restore.\n' % (
                n_found, total_to_check, pct_found, total_to_check - n_found))
            sys.stderr.flush()

    try:
        try:
            tar = open_tar_with_progress(archive, archive_size, progress_interval=5)
            with tar:
                item = tar.next()
                while item is not None:
                    target_path = os.path.normpath(restore_base + '/' + item.name)
                    manifest_key = '/' + item.name
                    if manifest_key in pre_skipped_paths_single:
                        processed += 1
                        if not verbose and total_files > 0:
                            pct = 100 * processed // total_files
                            sys.stderr.write(
                                '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                            sys.stderr.flush()
                        item = tar.next()
                        continue
                    checksum = ''
                    if manifest_key in manifest.get('modified', {}):
                        checksum = manifest['modified'][manifest_key].get('checksum', '')
                    decision, skip_reason = check_conflict(target_path, checksum, conflict_mode)
                    if decision == 'abort':
                        restore_failed_single = True
                        logging.error(
                            'Conflict at "%s" (file exists, content differs). '
                            'Use --conflict replace to overwrite (default is skipsame: skip only when same).',
                            target_path)
                        sys.exit(1)
                    if decision == 'skip':
                        restore_outcome_single[manifest_key] = 'skipped'
                        skip_reasons_single[manifest_key] = skip_reason or 'unknown'
                        if os.path.isfile(target_path):
                            _append_completed_lst(completed_lst_path, manifest_key, os.path.getsize(target_path))
                        if verbose:
                            logging.info('Skipping existing "%s"', target_path)
                        processed += 1
                        if not verbose and total_files > 0:
                            pct = 100 * processed // total_files
                            sys.stderr.write(
                                '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                            sys.stderr.flush()
                        item = tar.next()
                        continue
                    if conflict_mode == 'replace' and os.path.exists(target_path):
                        try:
                            if os.path.isdir(target_path) and not os.path.islink(target_path):
                                shutil.rmtree(target_path)
                            else:
                                os.unlink(target_path)
                        except OSError as exc:
                            logging.warning('Unable to remove existing "%s": %s', target_path, exc)
                    if verbose:
                        logging.info(
                            'Extracting "%s" to "%s"',
                            os.path.basename(target_path),
                            os.path.dirname(target_path))
                    tar.extract(item, cmdline.restore)
                    restore_outcome_single[manifest_key] = 'restored'
                    if os.path.isfile(target_path):
                        _append_completed_lst(completed_lst_path, manifest_key, os.path.getsize(target_path))
                    processed += 1
                    if not verbose and total_files > 0:
                        pct = 100 * processed // total_files
                        sys.stderr.write(
                            '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                        sys.stderr.flush()
                    item = tar.next()
            sys.stderr.write('\n')
            sys.stderr.flush()
        except Exception:
            restore_failed_single = True
            raise
    finally:
        if cmdline.restore:
            extra_paths_single = []
            if getattr(cmdline, 'show_extras', False):
                extra_paths_single = collect_extra_paths(
                    restore_base, set(merged_single.keys()),
                    _restore_temp_dir(restore_base, cmdline), REPORT_FILENAME_PREFIX)
            write_restore_report(
                restore_base, archive_names_single, merged_single, deleted_list_single,
                moved_info_single, restore_outcome_single, failed=restore_failed_single,
                skip_reasons=skip_reasons_single, invocation=' '.join(sys.argv),
                show_extras=getattr(cmdline, 'show_extras', False), extra_paths=extra_paths_single)
    if not verbose and total_files > 0:
        sys.stderr.write('\n')
        sys.stderr.flush()
    logging.info("Backup has been restored")
finally:
    if 'parity_repair_cleanup' in locals() and parity_repair_cleanup and os.path.isdir(parity_repair_cleanup):
        try:
            shutil.rmtree(parity_repair_cleanup)
        except OSError as exc:
            logging.warning('Could not remove parity repair dir %s: %s', parity_repair_cleanup, exc)
    if single_backup_cleanup_work and os.path.isdir(single_backup_cleanup_work):
        try:
            shutil.rmtree(single_backup_cleanup_work)
        except OSError as exc:
            logging.warning('Could not remove temp work dir %s: %s', single_backup_cleanup_work, exc)
    if temp_keyring_dir and 'GNUPGHOME' in os.environ and os.environ['GNUPGHOME'] == temp_keyring_dir:
        if old_gnupghome is not None:
            os.environ['GNUPGHOME'] = old_gnupghome
        else:
            del os.environ['GNUPGHOME']
    secure_wipe_temp_dir(temp_keyring_dir)
