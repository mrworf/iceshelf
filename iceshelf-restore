                        except OSError:
                            pass
                # Only remove directory if empty (leave .restore/completed.lst for resume)
                try:
                    if not os.listdir(restore_temp_dir):
                        os.rmdir(restore_temp_dir)
                except OSError:
                    pass
            except OSError:
                pass
        extra_paths = []
        if getattr(cmdline, 'show_extras', False):
