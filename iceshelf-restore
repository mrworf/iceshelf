def _is_gpg_encrypted(filepath, keyring_dir=None):
    """Return True if the file is OpenPGP-encrypted (not just signed). Uses gpg --list-packets."""
    env = gpg_module.gpg_env(keyring_dir)
    try:
        result = subprocess.run(
            ['gpg', '--list-packets', filepath],
            capture_output=True,
            text=True,
            env=env,
            timeout=30,
        )
        out = (result.stdout or '') + (result.stderr or '')
        return 'pubkey enc packet' in out or 'encrypted data packet' in out
    except (OSError, subprocess.TimeoutExpired):
        return False


def _path_inside(parent_dir, path):
    """Return True if path is under parent_dir (or equal). Used to avoid deleting source files."""
    try:
        return os.path.commonpath([os.path.abspath(parent_dir), os.path.abspath(path)]) == os.path.abspath(parent_dir)
    except ValueError:
        return False


def _strip_one_suffix(basename):
    """Return basename with one layer of .sig/.asc/.gpg stripped. Caller checks it ends with one of these."""
    ext = basename[-4:]
    base = basename[:-4]
    if base[-4:] == '.gpg' and ext == '.asc':
        base = base[:-4] + ext
    return base


def _final_stripped_basename(basename):
    """Return basename after all .sig/.asc/.gpg layers are stripped (e.g. archive.tar.bz2.gpg -> archive.tar.bz2)."""
    result = basename
    while result.endswith('.sig') or result.endswith('.asc') or result.endswith('.gpg'):
        result = _strip_one_suffix(result)
    return result


def _should_verify_signature(filepath, keyring_dir=None):
    """Return False if we should skip verification (file is encrypted); True to run verify."""
    if '.gpg.asc' in filepath or '.gpg.sig' in filepath or filepath.endswith('.gpg'):
        return False
    if filepath.endswith('.asc') or filepath.endswith('.sig'):
        if _is_gpg_encrypted(filepath, keyring_dir):
            return False
    return True


def validate_file(filepath, keyring_dir=None):
    """Verify GPG signatures when present. Skip verify for encrypted files (decrypt only)."""
    logging.debug('Validating "%s"', filepath)

    if filepath.endswith('.sig') or filepath.endswith('.asc'):
        if not _should_verify_signature(filepath, keyring_dir):
            return True
        if config.get('skip_signature'):
            return True
        if config.get('cannot_validate_signatures'):
            logging.error(
                'Signature present but cannot validate (no public key in key file). '
                'Rerun with --skip-signature to skip signature verification.')
            return False
        ok, stderr = gpg_module.gpg_verify(
            filepath, keyring_dir, skip_signature=config.get('skip_signature'))
        if not ok:
            logging.error(
                'Signature verification failed: %s',
                filepath)
            if stderr:
                logging.error('gpg: %s', stderr)
            logging.info(
                'Run "gpg --verify %s" to see GPG\'s error; with --key-file the signer\'s key must be in that file.',
                filepath)
            return False
    return True


def _gpg_failure_reason(stderr_text):
    """Derive a short user-facing reason from GPG stderr (or return None for generic)."""
    if not stderr_text:
        return None
    low = stderr_text.lower()
    if 'untrusted key' in low or 'using untrusted key' in low:
        return 'signature key not in keyring or not trusted (use --key-file or import the key)'
    if 'no public key' in low or 'no_pubkey' in low:
        return 'signing key not in keyring (use --key-file with the backup\'s public key)'
    if 'badsig' in low or 'bad signature' in low:
        return 'signature verification failed'
    if 'decryption failed' in low or 'no secret key' in low:
        return 'decryption failed (wrong passphrase or key not in keyring)'
    return None


def _can_attempt_parity_repair(corrupt_files, parity_files):
    """Return True when the only detected corruption is in the archive/parity set."""
    if not parity_files or not corrupt_files:
        return False

    saw_archive = False
    for path in corrupt_files:
        if '.json' in path or path.endswith('.lst') or 'filelist.txt' in path:
            return False
        if '.tar' in path:
            saw_archive = True
            continue
        if '.par2' in path:
            continue
        return False
    return saw_archive


def strip_file(filename, keyring_dir=None, output_path=None, work_dir=None,
              progress_interval=0, progress_original_size=None):
    """Strip signatures and decrypt files as needed.
    If output_path is given, the final stripped/decrypted file is written there.
    If work_dir is given, all intermediates and final output go under work_dir (read from source
    directly on first step to save space; never write or delete in the source directory).
    When progress_interval > 0 and progress_original_size is set, a progress line is shown every
    progress_interval seconds (after an initial delay of that length) during decryption.
    Returns (path, None) on success, (None, error_reason) on failure.
    """
    logging.debug('Processing "%s"', filename)

    current = filename
    source_dir = os.path.dirname(os.path.abspath(filename))
    passphrase = config.get('encrypt-pw')

    while current.endswith('.sig') or current.endswith('.asc') or current.endswith('.gpg'):
        base = os.path.basename(current)
        next_basename = _strip_one_suffix(base)
        two_layers = (base.endswith('.gpg.sig') or base.endswith('.gpg.asc'))
        if two_layers:
            final_basename = _final_stripped_basename(base)
            if output_path is not None and final_basename == os.path.basename(output_path):
                next_path = output_path
            elif work_dir is not None:
                next_path = os.path.join(work_dir, final_basename)
            else:
                next_path = os.path.join(source_dir, final_basename)
        else:
            if output_path is not None and next_basename == _final_stripped_basename(base):
                next_path = output_path
            elif work_dir is not None:
                next_path = os.path.join(work_dir, next_basename)
            else:
                next_path = os.path.join(source_dir, next_basename)
        if os.path.exists(next_path):
            try:
                os.unlink(next_path)
            except OSError as exc:
                logging.warning('Could not remove temp file %s: %s', next_path, exc)

        progress_thread = None
        stop_progress = None
        if progress_interval > 0 and progress_original_size is not None:
            stop_progress = threading.Event()

            def run_decrypt_progress():
                time.sleep(progress_interval)
                while not stop_progress.is_set():
                    out_size = os.path.getsize(next_path) if os.path.exists(next_path) else 0
                    out_mb = out_size / (1024 * 1024)
                    orig_mb = progress_original_size / (1024 * 1024)
                    if two_layers:
                        msg = '\r  Verifying and decrypting... %.1f MB (original file %.1f MB)    '
                    elif current.endswith('.sig') or current.endswith('.asc'):
                        msg = '\r  Verifying signature... %.1f MB (original file %.1f MB)    '
                    else:
                        msg = '\r  Decrypted %.1f MB (original file %.1f MB)    '
                    sys.stderr.write(msg % (out_mb, orig_mb))
                    sys.stderr.flush()
                    if stop_progress.wait(progress_interval):
                        break

            progress_thread = threading.Thread(target=run_decrypt_progress, daemon=True)
            progress_thread.start()

        try:
            if two_layers:
                ok, msg = gpg_module.gpg_decrypt_piped(
                    current, next_path, keyring_dir, passphrase)
            else:
                ok, msg = gpg_module.gpg_decrypt_one(
                    current, next_path, keyring_dir, passphrase)
        except OSError as exc:
            logging.error('Unable to decrypt "%s": %s', current, exc)
            return (None, str(exc))
        finally:
            if progress_thread is not None and stop_progress is not None:
                stop_progress.set()
                progress_thread.join()
                if current.endswith('.sig') or current.endswith('.asc'):
                    sys.stderr.write('\n')
                    sys.stderr.flush()

        if not ok:
            summary = _gpg_failure_reason(msg) or 'GPG verification or decryption failed'
            signature_related = 'signature' in msg.lower()
            good_sig_untrusted = (
                signature_related
                and 'good signature' in msg.lower()
                and 'untrusted' in msg.lower()
                and os.path.exists(next_path)
                and os.path.getsize(next_path) > 0)
            skip_ok = (
                signature_related
                and config.get('skip_signature')
                and os.path.exists(next_path))
            if good_sig_untrusted:
                logging.debug(
                    'Decryption succeeded (good signature, key untrusted in trustdb); continuing.')
            elif skip_ok:
                logging.warning(
                    'File "%s" lacked signature; --skip-signature is enabled, continuing.',
                    current)
            else:
                if signature_related and not config.get('skip_signature'):
                    logging.error(
                        'Rerun with --skip-signature for backups without a signature.')
                logging.error(
                    'GPG decryption failed for "%s": %s\n\n%s',
                    current, summary, msg)
                if os.path.exists(next_path) and (work_dir is None or _path_inside(work_dir, next_path)):
                    try:
                        os.unlink(next_path)
                    except OSError:
                        pass
                return (None, summary)
        if not os.path.exists(next_path):
            logging.error('Unable to decrypt: %s', current)
            return (None, msg or 'unknown reason')

        if work_dir is not None and _path_inside(work_dir, current):
            try:
                os.unlink(current)
            except OSError as exc:
                logging.warning('Could not remove temp file %s: %s', current, exc)

        current = next_path

    if output_path is not None:
        # When we wrote directly to output_path on the last step, current == output_path (no copy).
        # Only copy when zero decryption steps (file was already plain).
        if os.path.abspath(current) != os.path.abspath(output_path):
            try:
                shutil.copy2(current, output_path)
            except OSError as exc:
                logging.error('Failed to write decrypted archive to %s: %s', output_path, exc)
                return (None, str(exc))
        if work_dir is not None and _path_inside(work_dir, current) and os.path.abspath(current) != os.path.abspath(output_path):
            try:
                os.unlink(current)
            except OSError as exc:
                logging.warning('Could not remove temp file %s: %s', current, exc)
        return (output_path, None)
    return (current, None)


class _ProgressFileReader:
    """File-like wrapper that counts bytes read for progress reporting."""

    def __init__(self, path):
        self._file = open(path, 'rb')
        self._bytes_read = 0

    def read(self, size=-1):
        data = self._file.read(size)
        self._bytes_read += len(data)
        return data

    def readinto(self, b):
        n = self._file.readinto(b)
        if n is not None:
            self._bytes_read += n
        return n

    def seek(self, offset, whence=os.SEEK_SET):
        return self._file.seek(offset, whence)

    def seekable(self):
        return self._file.seekable()

    def readable(self):
        return self._file.readable()

    def tell(self):
        return self._file.tell()

    def close(self):
        return self._file.close()

    def __enter__(self):
        return self

    def __exit__(self, *args):
        self._file.close()


def open_tar_with_progress(archive_path, archive_size_bytes, progress_interval=5):
    """Open a tar archive (possibly compressed) with optional progress during the initial read.
    If progress_interval > 0 and archive_size_bytes is not None, a progress line is shown every
    progress_interval seconds (after an initial delay of that length) while the archive is read.
    Returns a tarfile.TarFile; the caller should use it in a 'with' block.
    """
    if progress_interval <= 0 or archive_size_bytes is None:
        return tarfile.open(archive_path, "r:*")

    wrapper = _ProgressFileReader(archive_path)
    stop_progress = threading.Event()

    def run_open_progress():
        time.sleep(progress_interval)
        while not stop_progress.is_set():
            out_mb = wrapper._bytes_read / (1024 * 1024)
            orig_mb = archive_size_bytes / (1024 * 1024)
            sys.stderr.write(
                '\r  Opening compressed archive... %.1f MB read (archive %.1f MB)    '
                % (out_mb, orig_mb))
            sys.stderr.flush()
            if stop_progress.wait(progress_interval):
                break

    progress_thread = threading.Thread(target=run_open_progress, daemon=True)
    progress_thread.start()
    try:
        tar = tarfile.open(fileobj=wrapper, mode="r:*")
        return tar
    finally:
        stop_progress.set()
        progress_thread.join()


def get_all_backup_basenames(base_dir):
    """
    Discover all backup basenames that have a manifest (archive optional).
    Uses only iceshelf's established filename patterns; derives basenames by
    stripping known suffixes. Returns sorted list (chronological order).
    Includes manifest-only backups (e.g. deleted-only, moved-only) so their
    metadata is applied during merge.
    """
    if base_dir == '':
        base_dir = './'
    if not os.path.isdir(base_dir):
        return []
    has_manifest = set()
    has_archive = set()
    try:
        entries = os.listdir(base_dir)
    except OSError:
        return []
    for entry in entries:
        for suffix in MANIFEST_SUFFIXES:
            if entry.endswith(suffix):
                base = entry[:-len(suffix)]
                has_manifest.add(base)
                break
        for suffix in ARCHIVE_SUFFIXES:
            if entry.endswith(suffix):
                base = entry[:-len(suffix)]
                has_archive.add(base)
                break
    restorable = sorted(has_manifest)
    return restorable


def determine_backup_basename(files):
    """Return the backup basename for a matched backup file set."""
    basename = None
    for entry in files:
        for suffix in MANIFEST_SUFFIXES + ARCHIVE_SUFFIXES:
            if entry.endswith(suffix):
                basename = entry[:-len(suffix)]
                break
        if basename:
            break
    return basename


def getBackupFiles(itemFromBackup):
    """Locate all files belonging to a backup based on a path or prefix.
    Returns (backup_dir, matched_files, all_basenames).
    all_basenames is only set when itemFromBackup is a directory (list of restorable backups).
    """
    backup_dir = os.path.dirname(itemFromBackup)
    basename = os.path.basename(itemFromBackup)
    all_basenames = None

    if os.path.isdir(itemFromBackup):
        backup_dir = itemFromBackup
        basename = None
        all_basenames = get_all_backup_basenames(backup_dir)

    if backup_dir == '':
        backup_dir = './'

    if basename and '.' in basename:
        # Resolve base by stripping known iceshelf suffixes
        for suffix in MANIFEST_SUFFIXES + ARCHIVE_SUFFIXES + FILELIST_SUFFIXES + ACTIVITY_LOG_SUFFIXES:
            if basename.endswith(suffix):
                candidate = basename[:-len(suffix)]
                if (get_manifest_file(backup_dir, candidate) or
                        get_archive_file(backup_dir, candidate)):
                    basename = candidate
                    break
        else:
            basename = basename.split('.', 1)[0]
    elif not basename:
        if all_basenames:
            basename = all_basenames[0]
        else:
            try:
                for entry in os.listdir(backup_dir):
                    for suffix in MANIFEST_SUFFIXES + ARCHIVE_SUFFIXES:
                        if entry.endswith(suffix):
                            candidate = entry[:-len(suffix)]
                            if (get_manifest_file(backup_dir, candidate) or
                                    get_archive_file(backup_dir, candidate)):
                                basename = candidate
                                break
                    if basename:
                        break
            except OSError:
                pass

    matched_files = restoreutils.get_files_for_basename(backup_dir, basename) if basename else []
    for entry in matched_files:
        logging.debug('Found backup file "%s"', entry)

    return (backup_dir, matched_files, all_basenames)


def _dest_has_same_checksum(dest_path, manifest_checksum, progress_callback=None):
    """Return True if the file at dest_path has the same checksum as manifest_checksum.
    progress_callback(bytes_done, total) is used during hash if provided."""
    if not manifest_checksum or not os.path.isfile(dest_path):
        return False
    if ':' in manifest_checksum:
        algo = manifest_checksum.split(':', 1)[1]
        current = fileutils.hashFile(dest_path, algo, True, progress_callback=progress_callback)
        return current == manifest_checksum
    # Legacy hex-only checksum: infer algorithm from length and compare
    length = len(manifest_checksum)
    algo = None
    if length == 32:
        algo = 'md5'
    elif length == 40:
        algo = 'sha1'
    elif length == 64:
        algo = 'sha256'
    elif length == 56:
        algo = 'sha224'
    elif length == 96:
        algo = 'sha384'
    elif length == 128:
        algo = 'sha512'
    if algo is None:
        return False
    current = fileutils.hashFile(dest_path, algo, False, progress_callback=progress_callback)
    return current == manifest_checksum


def check_conflict(restore_path, manifest_checksum, conflict_mode):
    """
    Check if restoring to restore_path would conflict with an existing path.
    Returns: (decision, skip_reason) where decision is 'proceed' | 'skip' | 'abort'.
    skip_reason is a human-readable string when decision == 'skip', else None.
    On 'abort' the caller should sys.exit(1).
    """
    if not os.path.exists(restore_path):
        return ('proceed', None)
    if conflict_mode == 'replace':
        return ('proceed', None)
    if conflict_mode == 'abort':
        return ('abort', None)
    if conflict_mode == 'skipsame':
        if os.path.isfile(restore_path) and _dest_has_same_checksum(restore_path, manifest_checksum):
            return ('skip', 'already existed, same content (--conflict skipsame)')
        return ('abort', None)
    return ('proceed', None)




# Orderings: index 0 = least wrapped, higher = more wrapped (used to detect left-overs)
_MANIFEST_SUFFIXES_ORDER = ('.json', '.json.gpg', '.json.asc', '.json.gpg.asc')
_ARCHIVE_SUFFIXES_ORDER = ('.tar', '.tar.gpg', '.tar.gpg.sig', '.tar.bz2', '.tar.bz2.gpg', '.tar.bz2.gpg.sig')
_FILELIST_SUFFIXES_ORDER = ('.lst', '.lst.asc')


def detect_leftovers(basepath, basename, manifest_path, archive_path, filelist_path=None):
    """Find files in basepath that look like less-wrapped versions of the chosen backup files.
    Log a single warning if any are found (informational: may be from prior runs).
    """
    leftovers = []
    basepath_abs = os.path.abspath(basepath)

    def chosen_suffix(path, order_tuple):
        if not path or not os.path.isfile(path):
            return None
        name = os.path.basename(path)
        if not name.startswith(basename):
            return None
        suffix = name[len(basename):]
        try:
            idx = order_tuple.index(suffix)
            return idx
        except ValueError:
            return None

    def collect_less_wrapped(order_tuple, chosen_idx, kind_label):
        if chosen_idx is None:
            return
        for i, suf in enumerate(order_tuple):
            if i >= chosen_idx:
                continue
            path = os.path.join(basepath, basename + suf)
            if os.path.isfile(path) and os.path.abspath(path).startswith(basepath_abs):
                leftovers.append(os.path.basename(path))

    m_idx = chosen_suffix(manifest_path, _MANIFEST_SUFFIXES_ORDER)
    a_idx = chosen_suffix(archive_path, _ARCHIVE_SUFFIXES_ORDER)
    fl_idx = chosen_suffix(filelist_path, _FILELIST_SUFFIXES_ORDER) if filelist_path else None

    collect_less_wrapped(_MANIFEST_SUFFIXES_ORDER, m_idx, 'manifest')
    collect_less_wrapped(_ARCHIVE_SUFFIXES_ORDER, a_idx, 'archive')
    collect_less_wrapped(_FILELIST_SUFFIXES_ORDER, fl_idx, 'filelist')

    if leftovers:
        logging.warning(
            'Left-over file(s) from prior runs found in backup folder (ignored, using highest-level version): %s',
            ', '.join(sorted(leftovers)))


def _parent_backup(manifest):
    """Return parent backup id from manifest (lastbackup or previousbackup)."""
    return manifest.get('lastbackup') or manifest.get('previousbackup')


def run_manifest_analysis(basepath, basenames, keyring_dir, activity_setting):
    """Load manifests, analyze their activity, and print the report."""
    manifests_by_basename = {}
    work_dir = tempfile.mkdtemp(prefix='iceshelf-restore.')
    try:
        for basename in basenames:
            manifest_path = get_manifest_file(basepath, basename)
            if not manifest_path:
                logging.error('Backup "%s" missing manifest', basename)
                return 1
            if not validate_file(manifest_path, keyring_dir):
                logging.error(
                    'Manifest validation failed for "%s". Ensure it is signed with a key in your keyring.',
                    os.path.basename(manifest_path))
                return 1
            stripped_manifest, strip_err = strip_file(manifest_path, keyring_dir, work_dir=work_dir)
            if stripped_manifest is None:
                logging.error(
                    'Unable to process manifest "%s": %s',
                    os.path.basename(manifest_path),
                    strip_err or 'decryption or signature verification failed')
                return 1
            try:
                with open(stripped_manifest, encoding='utf-8') as fp:
                    manifests_by_basename[basename] = json.load(fp)
            except (OSError, json.JSONDecodeError) as exc:
                logging.error('Unable to load manifest "%s": %s', os.path.basename(manifest_path), exc)
                return 1

        report = restoreutils.analyze_manifest_history(manifests_by_basename)
        threshold = restoreutils.parse_analysis_threshold(activity_setting, report['total_actions'])
        for line in restoreutils.format_manifest_analysis(report, threshold):
            logging.info('%s', line)
        return 0
    finally:
        try:
            shutil.rmtree(work_dir)
        except OSError:
            pass


def get_chain_gaps(basepath, all_basenames, keyring_dir, config):
    """
    Load each backup's manifest and return set of parent backup ids that are not in all_basenames.
    Used when listing multiple backups to warn about missing backups in the chain.
    """
    missing = set()
    work_dir = tempfile.mkdtemp(prefix='iceshelf-restore.')
    try:
        for basename in all_basenames:
            manifest_path = get_manifest_file(basepath, basename)
            if not manifest_path:
                continue
            if not validate_file(manifest_path, keyring_dir):
                continue
            stripped, _ = strip_file(manifest_path, keyring_dir, work_dir=work_dir)
            if stripped is None:
                continue
            try:
                with open(stripped, encoding='utf-8') as fp:
                    manifest = json.load(fp)
                parent = _parent_backup(manifest)
                if parent and parent not in all_basenames:
                    missing.add(parent)
            except (OSError, json.JSONDecodeError):
                continue
    finally:
        try:
            shutil.rmtree(work_dir)
        except OSError:
            pass
    return missing


def merge_manifests(manifests_by_basename):
    """
    Merge manifests in chronological order (basenames already sorted).
    Returns dict: restore_path -> (backup_id, path_in_archive, checksum).
    restore_path and path_in_archive use leading slash (e.g. /path/to/file).
    """
    merged = {}
    for backup_id in manifests_by_basename:
        manifest = manifests_by_basename[backup_id]
        for path in manifest.get('deleted', []):
            path = path if path.startswith('/') else '/' + path
            merged.pop(path, None)
        for newpath, info in manifest.get('moved', {}).items():
            raw_info = info
            key_normalized = newpath if newpath.startswith('/') else '/' + newpath
            if isinstance(raw_info, str):
                # Legacy format: moved[old_path] = new_path (string)
                # Restore path = value (new path); key = old path
                restore_path = raw_info if raw_info.startswith('/') else '/' + raw_info
                oldpath = key_normalized
                merged.pop(oldpath, None)
                # Resolve which backup has this file (newest first)
                ref_id = backup_id
                path_in_archive = restore_path
                checksum = ''
                for cand_id in reversed(manifests_by_basename):
                    cand = manifests_by_basename[cand_id]
                    mod = cand.get('modified', {})
                    if restore_path in mod:
                        ref_id = cand_id
                        path_in_archive = restore_path
                        checksum = mod[restore_path].get('checksum', '')
                        break
                    if oldpath in mod:
                        ref_id = cand_id
                        path_in_archive = oldpath
                        checksum = mod[oldpath].get('checksum', '')
                        break
                merged[restore_path] = (ref_id, path_in_archive, checksum)
            else:
                # Dict format: restore path = key (newpath), file at original in reference backup
                info = _normalize_moved_entry(info, backup_id)
                oldpath = info.get('original', '')
                oldpath = oldpath if oldpath.startswith('/') else '/' + oldpath
                merged.pop(oldpath, None)
                ref_id = info.get('reference', backup_id)
                path_in_archive = oldpath
                checksum = ''
                if 'modified' in manifest and key_normalized in manifest['modified']:
                    checksum = manifest['modified'][key_normalized].get('checksum', '')
                merged[key_normalized] = (ref_id, path_in_archive, checksum)
        for path, meta in manifest.get('modified', {}).items():
            path = path if path.startswith('/') else '/' + path
            checksum = meta.get('checksum', '')
            merged[path] = (backup_id, path, checksum)
    return merged


def _norm_path(path):
    """Normalize path for report: leading slash, no trailing slash."""
    if not path:
        return path
    path = path if path.startswith('/') else '/' + path
    return path.rstrip('/') or '/'


def _normalize_moved_entry(info, backup_id):
    """Normalize a 'moved' entry value. Old format: string (original path). New format: dict with 'original' and 'reference'."""
    if isinstance(info, dict):
        return {
            'original': info.get('original', ''),
            'reference': info.get('reference', backup_id),
        }
    return {'original': info if isinstance(info, str) else '', 'reference': backup_id}


def build_deleted_list_multi(manifests_by_basename, all_basenames):
    """
    Walk manifests in chronological order; return list of (path, introduced_in, deleted_in)
    for paths that were introduced and later deleted.
    """
    seen = {}
    deleted_entries = []
    for backup_id in all_basenames:
        manifest = manifests_by_basename.get(backup_id, {})
        for path in manifest.get('deleted', []):
            path = _norm_path(path)
            if path in seen:
                deleted_entries.append((path, seen[path], backup_id))
            seen.pop(path, None)
        for newpath, info in manifest.get('moved', {}).items():
            info = _normalize_moved_entry(info, backup_id)
            newpath = _norm_path(newpath)
            oldpath = _norm_path(info.get('original', ''))
            seen.pop(oldpath, None)
            seen[newpath] = backup_id
        for path in manifest.get('modified', {}):
            path = _norm_path(path)
            seen[path] = backup_id
    return deleted_entries


def build_moved_info_multi(manifests_by_basename, merged):
    """
    For each path in merged that came from a 'moved' entry, return (original_path, reference_backup).
    reference_backup is from manifest moved entry or the backup that owns the path.
    """
    moved_info = {}
    for restore_path, (backup_id, _path_in_archive, _checksum) in merged.items():
        restore_path = _norm_path(restore_path)
        manifest = manifests_by_basename.get(backup_id, {})
        moved_entries = manifest.get('moved', {})
        if restore_path in moved_entries:
            info = _normalize_moved_entry(moved_entries[restore_path], backup_id)
            original = _norm_path(info.get('original', ''))
            reference = info.get('reference', backup_id)
            moved_info[restore_path] = (original, reference)
    return moved_info


REPORT_FILENAME_PREFIX = 'iceshelf-restore-report'


def collect_extra_paths(restore_base, merged_paths_set, restore_temp_dir, report_filename_prefix):
    """
    Walk the restore destination and return paths of files that exist on disk
    but are not in the backup (merged_paths_set). Paths are in the same
    normalized form as merged keys (leading slash, forward slashes).
    Excludes files under restore_temp_dir and audit report files.
    """
    if not restore_base or not os.path.isdir(restore_base):
        return []
    base_norm = os.path.normpath(restore_base)
    temp_norm = os.path.normpath(restore_temp_dir)
    extras = []
    try:
        for dirpath, _dirnames, filenames in os.walk(base_norm):
            for name in filenames:
                fullpath = os.path.join(dirpath, name)
                if _path_inside(temp_norm, fullpath):
                    continue
                if dirpath == base_norm and name.startswith(report_filename_prefix) and name.endswith('.txt'):
                    continue
                try:
                    rel = os.path.relpath(fullpath, base_norm)
                except ValueError:
                    continue
                path = '/' + rel.replace(os.sep, '/')
                if path not in merged_paths_set:
                    extras.append(path)
    except OSError:
        return []
    return sorted(extras)


def write_restore_report(restore_base, archive_names, merged, deleted_list, moved_info,
                         restore_outcome, failed=False, skip_reasons=None, invocation=None,
                         show_extras=False, extra_paths=None):
    """
    Write iceshelf-restore-report-YYYYMMDD-HHMMSS.txt in the root of restore_base.
    The timestamp in the filename matches the Date line in the report body.
    merged: dict path -> (backup_id, path_in_archive, checksum) for all paths that were to be restored.
    deleted_list: list of (path, introduced_in, deleted_in).
    moved_info: dict path -> (original_path, reference_backup) for paths that were moved.
    restore_outcome: dict path -> 'restored' | 'skipped' (only 'restored' appear in Restored section).
    skip_reasons: dict path -> reason string for paths that were skipped (conflict resolution).
    invocation: command line string to record how the tool was invoked.
    show_extras: if True and extra_paths non-empty, add a section listing unexpected files.
    extra_paths: list of paths (normalized) that exist in restore destination but were not in the backup.
    """
    if skip_reasons is None:
        skip_reasons = {}
    if extra_paths is None:
        extra_paths = []
    report_time = time.localtime()
    ts = time.strftime('%Y%m%d-%H%M%S', report_time)
    report_filename = '%s-%s.txt' % (REPORT_FILENAME_PREFIX, ts)
    lines = []
    lines.append('iceshelf-restore audit report')
    lines.append('Date: %s' % time.strftime('%Y-%m-%d %H:%M:%S', report_time))
    lines.append('Destination: %s' % os.path.normpath(restore_base or '.'))
    if invocation:
        lines.append('Command: %s' % invocation)
    if failed:
        lines.append('Restore status: failed')
    lines.append('')
    lines.append('=== Archives ===')
    for name in sorted(archive_names):
        lines.append(name)
    lines.append('')
    lines.append('=== Restored ===')
    for path in sorted(restore_outcome.keys()):
        if restore_outcome.get(path) != 'restored':
            continue
        backup_id = merged[path][0] if path in merged else '?'
        part = '%s (from %s)' % (path, backup_id)
        if path in moved_info:
            orig, ref = moved_info[path]
            part += '; introduced in %s as %s, moved to %s in %s' % (ref, orig, path, backup_id)
        lines.append(part)
    lines.append('')
    lines.append('=== Not restored (skipped) ===')
    for path in sorted(restore_outcome.keys()):
        if restore_outcome.get(path) != 'skipped':
            continue
        reason = skip_reasons.get(path, 'unknown')
        lines.append('%s — %s' % (path, reason))
    lines.append('')
    lines.append('=== Not restored (deleted) ===')
    for path, introduced_in, deleted_in in sorted(deleted_list, key=lambda x: x[0]):
        lines.append('%s — introduced in %s, deleted in %s' % (path, introduced_in, deleted_in))
    if show_extras and extra_paths:
        dest_label = os.path.normpath(restore_base or '.')
        lines.append('')
        lines.append('=== Unexpected files in restoration folder %s ===' % dest_label)
        for path in extra_paths:
            lines.append(path)
    lines.append('')
    lines.append('End of Report')
    report_path = os.path.join(restore_base or '.', report_filename)
    try:
        with open(report_path, 'w', encoding='utf-8') as fp:
            fp.write('\n'.join(lines))
            fp.write('\n')
    except OSError as exc:
        logging.warning('Could not write restore report to %s: %s', report_path, exc)


def _restore_temp_dir(restore_base, cmdline):
    """Resolve directory for temporary decrypted archives during multi-archive restore.
    Default: .restore under restore destination. Override with --restore-temp-dir (absolute or relative).
    """
    raw = getattr(cmdline, 'restore_temp_dir', None)
    if raw is None:
        return os.path.normpath(os.path.join(restore_base or '.', '.restore'))
    if os.path.isabs(raw):
        return os.path.normpath(raw)
    return os.path.normpath(os.path.join(restore_base or '.', raw))


def _completed_lst_path(restore_base, cmdline):
    """Return path to .restore/completed.lst for resumable restore progress."""
    return os.path.join(_restore_temp_dir(restore_base, cmdline), 'completed.lst')


def _load_completed_lst(completed_lst_path):
    """Load completed.lst; return dict path -> expected size. Skip malformed lines. Return {} if missing."""
    result = {}
    if not os.path.isfile(completed_lst_path):
        return result
    try:
        with open(completed_lst_path, 'r', encoding='utf-8') as fp:
            for line in fp:
                line = line.rstrip('\n')
                if not line:
                    continue
                parts = line.split('\t', 1)
                if len(parts) != 2:
                    logging.debug('Skipping malformed completed.lst line: %s', line[:80])
                    continue
                path, size_str = parts
                try:
                    result[path] = int(size_str)
                except ValueError:
                    logging.debug('Skipping completed.lst line with invalid size: %s', line[:80])
    except OSError as exc:
        logging.warning('Could not read completed.lst %s: %s', completed_lst_path, exc)
    return result


def _apply_completed_lst(restore_base, completed_lst_path, merged_paths, restore_outcome, skip_reasons):
    """
    Apply completed.lst: for each entry, if path in merged_paths and file exists with matching size,
    add to verified set and mark skipped. If size mismatch, remove file so it can be restored again.
    Return set of paths that were verified (caller adds to pre_skipped_paths).
    """
    merged_set = set(merged_paths)
    loaded = _load_completed_lst(completed_lst_path)
    total_loaded = len(loaded)
    if total_loaded > 0:
        sys.stderr.write('Applying completed.lst (resume check)\n')
        sys.stderr.flush()
    verified = set()
    for idx, (path, expected_size) in enumerate(loaded.items(), 1):
        if total_loaded > 0:
            pct = 100 * idx // total_loaded
            sys.stderr.write('\rChecking completed entry %d of %d (%d%%)    ' % (idx, total_loaded, pct))
            sys.stderr.flush()
        if path not in merged_set:
            continue
        dest_full = os.path.normpath(restore_base + path)
        if not os.path.isfile(dest_full):
            continue
        try:
            actual_size = os.path.getsize(dest_full)
        except OSError:
            continue
        if actual_size == expected_size:
            verified.add(path)
            restore_outcome[path] = 'skipped'
            skip_reasons[path] = 'completed in previous run (size match)'
        else:
            try:
                os.unlink(dest_full)
            except OSError as exc:
                logging.warning('Could not remove %s for re-restore: %s', dest_full, exc)
    if total_loaded > 0:
        sys.stderr.write('\n')
        sys.stderr.write('Checked %d completed entries.\n' % total_loaded)
        sys.stderr.flush()
    return verified


def _append_completed_lst(completed_lst_path, restore_path, size):
    """Append one path+size line to completed.lst; ensure parent dir exists; flush for durability."""
    parent = os.path.dirname(completed_lst_path)
    if parent:
        try:
            os.makedirs(parent, exist_ok=True)
        except OSError as exc:
            logging.warning('Could not create directory for completed.lst: %s', exc)
            return
    try:
        with open(completed_lst_path, 'a', encoding='utf-8') as fp:
            fp.write(restore_path + '\t' + str(size) + '\n')
            fp.flush()
    except OSError as exc:
        logging.warning('Could not append to completed.lst: %s', exc)


def run_multi_archive_restore(basepath, all_basenames, restore_base, config, cmdline, keyring_dir=None):
    """Restore all backups in order to restore_base, merging state and applying conflict policy."""
    n_backups = len(all_basenames)
    logging.info('Multi-archive restore: processing %d backup(s)', n_backups)
    manifests_by_basename = {}
    stripped_manifest_paths = []  # decrypted manifest .json files to remove so .restore can be deleted
    restore_temp_dir = None  # set when we need to decrypt manifest or archive
    for idx, basename in enumerate(all_basenames, 1):
        logging.info('Loading backup %d/%d: %s', idx, n_backups, basename)
        manifest_path = get_manifest_file(basepath, basename)
        archive_path = get_archive_file(basepath, basename)
        if not manifest_path:
            logging.error('Backup "%s" missing manifest', basename)
            sys.exit(1)
        if archive_path:
            file_manifest = os.path.basename(manifest_path)
            file_archive = os.path.basename(archive_path)
            detect_leftovers(basepath, basename, manifest_path, archive_path, None)
        else:
            detect_leftovers(basepath, basename, manifest_path, None, None)
        if not validate_file(manifest_path, keyring_dir):
            logging.error(
                'Manifest validation failed for "%s". '
                'Ensure all backups are signed with a key in your keyring (e.g. from --key-file).',
                basename)
            sys.exit(1)
        if restore_temp_dir is None:
            restore_temp_dir = _restore_temp_dir(restore_base, cmdline)
            try:
                os.makedirs(restore_temp_dir, exist_ok=True)
            except OSError as exc:
                logging.error('Cannot create restore temp dir "%s": %s', restore_temp_dir, exc)
                sys.exit(1)
        logging.info('  Decrypting manifest for %s...', basename)
        stripped_manifest, strip_err = strip_file(manifest_path, keyring_dir, work_dir=restore_temp_dir)
        if stripped_manifest is None:
            logging.error(
                'Unable to process manifest for "%s": %s',
                basename, strip_err or 'decryption or signature verification failed')
            sys.exit(1)
        with open(stripped_manifest, encoding='utf-8') as fp:
            manifest = json.load(fp)
        manifests_by_basename[basename] = manifest
        stripped_manifest_paths.append(stripped_manifest)

    # 2) Chain-gap warning
    missing = set()
    for backup_id, manifest in manifests_by_basename.items():
        parent = _parent_backup(manifest)
        if parent and parent not in all_basenames:
            missing.add(parent)
    if missing:
        logging.warning(
            'Backup(s) not found in folder: %s. Restored set may be incomplete.',
            ', '.join(sorted(missing)))

    # 3) Merge to get final path -> (backup_id, path_in_archive, checksum)
    logging.info('Merging manifests (%d backups) to compute final file set...', len(manifests_by_basename))
    merged = merge_manifests(manifests_by_basename)
    logging.info('Will restore %d file(s) to %s', len(merged), restore_base)

    if not cmdline.restore:
        return

    # Report data: archives (top-level names only), deleted list, moved info, restore outcome
    archive_names = []
    for b in all_basenames:
        ap = get_archive_file(basepath, b)
        if ap and os.path.isfile(ap):
            archive_names.append(os.path.basename(ap))
    deleted_list = build_deleted_list_multi(manifests_by_basename, all_basenames)
    moved_info = build_moved_info_multi(manifests_by_basename, merged)
    restore_outcome = {}
    skip_reasons = {}
    restore_failed = False

    # 4) Extract: group by backup, then for each path apply conflict check and extract
    conflict_mode = cmdline.conflict
    verbose = getattr(cmdline, 'verbose', False)
    by_backup = {}
    for restore_path, (backup_id, path_in_archive, checksum) in merged.items():
        by_backup.setdefault(backup_id, []).append((restore_path, path_in_archive, checksum))

    total_files = sum(len(entries) for entries in by_backup.values())
    processed = 0

    # Resumable restore: apply completed.lst (size match -> skip; mismatch -> remove file for re-restore)
    completed_lst_path = _completed_lst_path(restore_base, cmdline)
    verified = _apply_completed_lst(restore_base, completed_lst_path, merged.keys(), restore_outcome, skip_reasons)
    pre_skipped_paths = set(verified)

    # Preemptive skip: check destination before opening any archive (saves time on resume)
    if conflict_mode == 'skipsame':
        merged_list = list(merged.items())
        total_to_check = len(merged_list)
        sys.stderr.write('Locating already restored files\n')
        sys.stderr.flush()
        for idx, (restore_path, (_backup_id, _path_in_archive, checksum)) in enumerate(merged_list, 1):
            dest_full = os.path.normpath(restore_base + restore_path)
            pct_overall = 100 * idx // total_to_check if total_to_check else 0
            if restore_path in pre_skipped_paths:
                sys.stderr.write(
                    '\rChecking file %d of %d (%d%%): skipped (completed).    '
                    % (idx, total_to_check, pct_overall))
                sys.stderr.flush()
                continue
            if not os.path.isfile(dest_full):
                sys.stderr.write(
                    '\rChecking file %d of %d (%d%%): not present.    '
                    % (idx, total_to_check, pct_overall))
                sys.stderr.flush()
            else:
                def _hash_progress(bytes_done, total):
                    pct_file = 100 * bytes_done // total if total else 0
                    sys.stderr.write(
                        '\rChecking file %d of %d (%d%%): Calculating, %d%% done.    '
                        % (idx, total_to_check, pct_overall, pct_file))
                    sys.stderr.flush()
                if _dest_has_same_checksum(dest_full, checksum, progress_callback=_hash_progress):
                    pre_skipped_paths.add(restore_path)
                    restore_outcome[restore_path] = 'skipped'
                    skip_reasons[restore_path] = 'already existed, same content (--conflict skipsame)'
                    if os.path.isfile(dest_full):
                        _append_completed_lst(completed_lst_path, restore_path, os.path.getsize(dest_full))
        if merged_list:
            sys.stderr.write('\n')
            sys.stderr.flush()
            n_found = len(pre_skipped_paths)
            pct_found = 100 * n_found // total_to_check if total_to_check else 0
            sys.stderr.write('Found %d of %d (%d%%). %d to restore.\n' % (
                n_found, total_to_check, pct_found, total_to_check - n_found))
            sys.stderr.flush()

    try:
        try:
            for ext_idx, backup_id in enumerate(all_basenames, 1):
                if backup_id not in by_backup:
                    continue
                # After the first archive, progress was updated with \r (no newline); start new line
                if not verbose and total_files > 0 and ext_idx > 1:
                    sys.stderr.write('\n')
                    sys.stderr.flush()
                n_files = len(by_backup[backup_id])
                # Skip opening archive if all its files are already pre-skipped
                entries_this_backup = by_backup[backup_id]
                if all(rp in pre_skipped_paths for rp, _pi, _cs in entries_this_backup):
                    logging.info(
                        'Skipping archive %s (all %d file(s) already present)',
                        backup_id, n_files)
                    for _ in entries_this_backup:
                        processed += 1
                        if not verbose and total_files > 0:
                            pct = 100 * processed // total_files
                            sys.stderr.write(
                                '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                            sys.stderr.flush()
                    continue
                logging.info(
                    'Extracting from backup %d/%d: %s (%d file(s))',
                    ext_idx, n_backups, backup_id, n_files)
                archive_path = get_archive_file(basepath, backup_id)
                if not archive_path:
                    logging.error('Archive not found for "%s"', backup_id)
                    sys.exit(1)
                if not validate_file(archive_path, keyring_dir):
                    restore_failed = True
                    logging.error(
                        'Archive validation failed for "%s". '
                        'Ensure all backups are signed with a key in your keyring (e.g. from --key-file).',
                        backup_id)
                    sys.exit(1)
                logging.info(
                    '  Decrypting archive for %s (may take several minutes for large files)...',
                    backup_id)
                archive_original_size = os.path.getsize(archive_path)
                final_basename = _final_stripped_basename(os.path.basename(archive_path))
                direct_path = os.path.join(restore_temp_dir, final_basename)
                try:
                    stripped, strip_err = strip_file(
                        archive_path, keyring_dir, output_path=direct_path, work_dir=restore_temp_dir,
                        progress_interval=5, progress_original_size=archive_original_size)
                    if stripped is None:
                        logging.error(
                            'Unable to process archive for "%s": %s',
                            backup_id, strip_err or 'decryption or signature verification failed')
                        sys.exit(1)
                    sys.stderr.write('\n')
                    sys.stderr.flush()
                    tar = open_tar_with_progress(
                        direct_path, os.path.getsize(direct_path), progress_interval=5)
                    with tar:
                        for restore_path, path_in_archive, checksum in by_backup[backup_id]:
                            if restore_path in pre_skipped_paths:
                                processed += 1
                                if not verbose and total_files > 0:
                                    pct = 100 * processed // total_files
                                    sys.stderr.write(
                                        '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                                    sys.stderr.flush()
                                continue
                            dest_full = os.path.normpath(restore_base + restore_path)
                            decision, skip_reason = check_conflict(dest_full, checksum, conflict_mode)
                            if decision == 'abort':
                                restore_failed = True
                                logging.error(
                                    'Conflict at "%s" (file exists, content differs). '
                                    'Use --conflict replace to overwrite (default is skipsame: skip only when same).',
                                    dest_full)
                                sys.exit(1)
                            if decision == 'skip':
                                restore_outcome[restore_path] = 'skipped'
                                skip_reasons[restore_path] = skip_reason or 'unknown'
                                if os.path.isfile(dest_full):
                                    _append_completed_lst(completed_lst_path, restore_path, os.path.getsize(dest_full))
                                if verbose:
                                    logging.info('Skipping existing "%s"', dest_full)
                                processed += 1
                                if not verbose and total_files > 0:
                                    pct = 100 * processed // total_files
                                    sys.stderr.write(
                                        '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                                    sys.stderr.flush()
                                continue
                            dirname = os.path.dirname(dest_full)
                            if dirname:
                                try:
                                    os.makedirs(dirname, exist_ok=True)
                                except OSError as exc:
                                    restore_failed = True
                                    logging.error('Cannot create directory "%s": %s', dirname, exc)
                                    sys.exit(1)
                            if conflict_mode == 'replace' and os.path.exists(dest_full):
                                try:
                                    if os.path.isdir(dest_full) and not os.path.islink(dest_full):
                                        shutil.rmtree(dest_full)
                                    else:
                                        os.unlink(dest_full)
                                except OSError as exc:
                                    logging.warning('Unable to remove existing "%s": %s', dest_full, exc)
                            member_name = path_in_archive.lstrip('/')
                            try:
                                member = tar.getmember(member_name)
                            except tarfile.ReadError as e:
                                restore_failed = True
                                logging.error(
                                    'Archive "%s" appears truncated or corrupt (tar read error: %s). '
                                    'If using multi-archive restore, try restoring one backup at a time.',
                                    backup_id, e)
                                sys.exit(1)
                            except KeyError:
                                member = None
                                try:
                                    for m in tar.getmembers():
                                        if m.name == member_name or '/' + m.name == path_in_archive:
                                            member = m
                                            break
                                except tarfile.ReadError as e:
                                    restore_failed = True
                                    logging.error(
                                        'Archive "%s" appears truncated or corrupt (tar read error: %s). '
                                        'If using multi-archive restore, try restoring one backup at a time.',
                                        backup_id, e)
                                    sys.exit(1)
                            if member is None:
                                restore_failed = True
                                restore_outcome[restore_path] = 'skipped'
                                skip_reasons[restore_path] = 'not in archive'
                                logging.error('Archive "%s" does not contain "%s"', backup_id, path_in_archive)
                                processed += 1
                                if not verbose and total_files > 0:
                                    pct = 100 * processed // total_files
                                    sys.stderr.write(
                                        '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                                    sys.stderr.flush()
                                continue
                            is_moved = (_norm_path(path_in_archive) != _norm_path(restore_path))
                            if is_moved:
                                tar.extract(member, restore_temp_dir)
                                extracted_path = os.path.normpath(
                                    os.path.join(restore_temp_dir, path_in_archive.lstrip('/')))
                                dirname = os.path.dirname(dest_full)
                                if dirname:
                                    try:
                                        os.makedirs(dirname, exist_ok=True)
                                    except OSError as exc:
                                        restore_failed = True
                                        logging.error('Cannot create directory "%s": %s', dirname, exc)
                                        sys.exit(1)
                                try:
                                    shutil.move(extracted_path, dest_full)
                                except OSError as exc:
                                    restore_failed = True
                                    logging.error(
                                        'Failed to move extracted file from "%s" to "%s": %s',
                                        extracted_path, dest_full, exc)
                                    sys.exit(1)
                                extracted_dir = os.path.dirname(extracted_path)
                                while (extracted_dir and extracted_dir != restore_temp_dir
                                       and os.path.exists(extracted_dir)):
                                    try:
                                        os.rmdir(extracted_dir)
                                    except OSError:
                                        break
                                    extracted_dir = os.path.dirname(extracted_dir)
                            else:
                                tar.extract(member, restore_base)
                            restore_outcome[restore_path] = 'restored'
                            if os.path.isfile(dest_full):
                                _append_completed_lst(completed_lst_path, restore_path, os.path.getsize(dest_full))
                            if verbose:
                                logging.info('Extracted "%s" to "%s"', path_in_archive, dest_full)
                            processed += 1
                            if not verbose and total_files > 0:
                                pct = 100 * processed // total_files
                                sys.stderr.write(
                                    '\rExtracted %d files of %d (%d%% complete)    ' % (processed, total_files, pct))
                                sys.stderr.flush()
                    sys.stderr.write('\n')
                    sys.stderr.flush()
                finally:
                    try:
                        if os.path.isfile(direct_path):
                            os.unlink(direct_path)
                    except OSError as exc:
                        logging.warning('Could not remove temp decrypted archive %s: %s', direct_path, exc)
        except Exception:
            restore_failed = True
            raise
    finally:
        for path in stripped_manifest_paths:
            try:
                if os.path.isfile(path):
                    os.unlink(path)
            except OSError as exc:
                logging.warning('Could not remove temp manifest %s: %s', path, exc)
        if restore_temp_dir and os.path.isdir(restore_temp_dir):
            try:
                for entry in os.listdir(restore_temp_dir):
                    if entry == 'completed.lst':
                        continue
                    p = os.path.join(restore_temp_dir, entry)
                    if os.path.isfile(p):
