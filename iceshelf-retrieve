#!/usr/bin/env python3
"""Iceshelf Retrieve - fetch backups from AWS Glacier.

This tool downloads files created by `iceshelf` that were stored in an AWS
Glacier vault. Because Glacier retrievals are asynchronous, the tool keeps
track of in-progress jobs and can be re-run to continue where it left off.
"""

import argparse
import logging
import json
import os
import re
import sys
import threading
import time
from queue import Queue

import boto3
import yaml
from botocore.exceptions import ClientError, NoCredentialsError, NoRegionError

from modules import aws


STATE_VERSION = 1

# Sentinel put on the download queue to tell workers to exit
_DOWNLOAD_QUEUE_SENTINEL = None

AWS_CONFIG_KEYS = (
    "region",
    "access_key_id",
    "secret_access_key",
    "session_token",
    "profile",
    "endpoint_url",
)


def load_aws_config_file(path):
    """Load AWS config from a YAML file. Returns a dict with only known keys."""
    if not path or not os.path.exists(path):
        return {}
    with open(path, "r", encoding="utf-8") as f:
        data = yaml.safe_load(f) or {}
    return {k: data[k] for k in AWS_CONFIG_KEYS if k in data and data[k] is not None}


def merge_aws_config(file_config, args):
    """Merge file config with CLI args. CLI overrides. Returns dict for boto3."""
    merged = dict(file_config)
    if getattr(args, "aws_region", None):
        merged["region"] = args.aws_region
    if getattr(args, "aws_access_key_id", None):
        merged["access_key_id"] = args.aws_access_key_id
    if getattr(args, "aws_secret_access_key", None):
        merged["secret_access_key"] = args.aws_secret_access_key
    if getattr(args, "aws_session_token", None):
        merged["session_token"] = args.aws_session_token
    if getattr(args, "aws_profile", None):
        merged["profile"] = args.aws_profile
    if getattr(args, "aws_endpoint_url", None):
        merged["endpoint_url"] = args.aws_endpoint_url
    return merged


def create_glacier_client(aws_config):
    """Create a boto3 Glacier client from merged config. Returns (client, None) or (None, error_msg)."""
    region = aws_config.get("region")
    access_key_id = aws_config.get("access_key_id")
    secret_access_key = aws_config.get("secret_access_key")
    session_token = aws_config.get("session_token")
    profile = aws_config.get("profile")
    endpoint_url = aws_config.get("endpoint_url")

    if not region:
        return (
            None,
            "AWS region is required. Use: --aws-region us-east-1 (or set 'region' in config file).",
        )
    has_explicit_creds = access_key_id and secret_access_key
    if not has_explicit_creds and not profile:
        return (
            None,
            "AWS credentials required. Use: --aws-access-key-id KEY --aws-secret-access-key SECRET (or set in config file), or --aws-profile NAME.",
        )

    try:
        if has_explicit_creds:
            session = boto3.Session(
                aws_access_key_id=access_key_id,
                aws_secret_access_key=secret_access_key,
                aws_session_token=session_token,
                region_name=region,
            )
        else:
            session = boto3.Session(profile_name=profile, region_name=region)
        client_kwargs = {"service_name": "glacier", "region_name": region}
        if endpoint_url:
            client_kwargs["endpoint_url"] = endpoint_url
        client = session.client(**client_kwargs)
        return (client, None)
    except NoRegionError:
        return (
            None,
            "AWS region is required. Use: --aws-region REGION (or set 'region' in config file).",
        )
    except NoCredentialsError:
        return (
            None,
            "AWS credentials required. Use: --aws-access-key-id and --aws-secret-access-key (or set in config file), or --aws-profile NAME.",
        )
    except ClientError as e:
        code = e.response.get("Error", {}).get("Code", "Unknown")
        return (
            None,
            f"AWS error ({code}). Check vault name, permissions, and network.",
        )
    except Exception as e:
        return (None, str(e))


def ensure_inventory(client, vault, datadir, wait_until_ready=False, poll_interval_secs=900):
    """Ensure a recent inventory is available.

    Returns a dictionary mapping archive description to information or None if
    the inventory is still being prepared (and wait_until_ready is False).
    """
    inv_file = os.path.join(datadir, "glacier_inventory.json")
    job_file = os.path.join(datadir, "glacier_inventory.job")

    if os.path.exists(inv_file):
        with open(inv_file, "r", encoding="utf-8") as f:
            data = json.load(f)
        mapping = {}
        for a in data.get("ArchiveList", []):
            mapping[a.get("ArchiveDescription")] = {
                "archiveId": a.get("ArchiveId"),
                "size": a.get("Size"),
                "checksum": a.get("SHA256TreeHash"),
            }
        return mapping

    if os.path.exists(job_file):
        with open(job_file, "r", encoding="utf-8") as f:
            job_id = f.read().strip()
        logging.info("Checking status of inventory job %s", job_id)
        status = client.describe_job(vaultName=vault, jobId=job_id)
        while not status.get("Completed"):
            if not wait_until_ready:
                logging.info(
                    "Inventory job not ready yet. Please rerun later."
                    " Use --wait to have the tool wait until the inventory is ready."
                )
                return None
            interval_mins = poll_interval_secs // 60
            logging.info(
                "Waiting for inventory job (polling every %d minutes)...", interval_mins
            )
            time.sleep(poll_interval_secs)
            status = client.describe_job(vaultName=vault, jobId=job_id)
        logging.info("Downloading inventory ...")
        out = client.get_job_output(vaultName=vault, jobId=job_id)
        body = out["body"].read()
        with open(inv_file, "wb") as f:
            f.write(body)
        os.remove(job_file)
        data = json.loads(body.decode("utf-8"))
        mapping = {}
        for a in data.get("ArchiveList", []):
            mapping[a.get("ArchiveDescription")] = {
                "archiveId": a.get("ArchiveId"),
                "size": a.get("Size"),
                "checksum": a.get("SHA256TreeHash"),
            }
        return mapping

    # No job running, start one
    logging.info("Starting inventory retrieval job ...")
    resp = client.initiate_job(
        vaultName=vault,
        jobParameters={"Type": "inventory-retrieval"},
    )
    job_id = resp["jobId"]
    with open(job_file, "w", encoding="utf-8") as f:
        f.write(job_id)
    if not wait_until_ready:
        logging.info(
            "Inventory retrieval job %s started. Rerun the tool once it completes.",
            job_id,
        )
        return None
    # Fall through to poll for the job we just started
    status = client.describe_job(vaultName=vault, jobId=job_id)
    while not status.get("Completed"):
        interval_mins = poll_interval_secs // 60
        logging.info(
            "Waiting for inventory job (polling every %d minutes)...", interval_mins
        )
        time.sleep(poll_interval_secs)
        status = client.describe_job(vaultName=vault, jobId=job_id)
    logging.info("Downloading inventory ...")
    out = client.get_job_output(vaultName=vault, jobId=job_id)
    body = out["body"].read()
    with open(inv_file, "wb") as f:
        f.write(body)
    os.remove(job_file)
    data = json.loads(body.decode("utf-8"))
    mapping = {}
    for a in data.get("ArchiveList", []):
        mapping[a.get("ArchiveDescription")] = {
            "archiveId": a.get("ArchiveId"),
            "size": a.get("Size"),
            "checksum": a.get("SHA256TreeHash"),
        }
    return mapping


def load_state(path):
    if not os.path.exists(path):
        return {"version": STATE_VERSION, "files": {}}
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def save_state(path, state):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, path)


def request_job(client, vault, entry):
    resp = client.initiate_job(
        vaultName=vault,
        jobParameters={
            "Type": "archive-retrieval",
            "ArchiveId": entry["archiveId"],
            "Description": entry["name"],
        },
    )
    entry["jobId"] = resp["jobId"]
    entry["status"] = "requested"
    logging.info("Requested retrieval of %s (job %s)", entry["name"], entry["jobId"])


def check_job(client, vault, entry):
    info = client.describe_job(vaultName=vault, jobId=entry["jobId"])
    if not info.get("Completed"):
        logging.info("%s not ready yet", entry["name"])
        return False
    entry["status"] = "ready"
    return True


def download_job(client, vault, entry, destdir):
    dest = os.path.join(destdir, entry["name"])
    logging.info("Downloading %s", entry["name"])
    start = time.time()
    out = client.get_job_output(vaultName=vault, jobId=entry["jobId"])
    with open(dest, "wb") as f:
        while True:
            chunk = out["body"].read(1024 * 1024)
            if not chunk:
                break
            f.write(chunk)
            if sys.stdout.isatty():
                done = f.tell()
                total = entry.get("size", 0)
                speed = done / max(time.time() - start, 1)
                sys.stdout.write(
                    "%s: %s/%s @ %s\r"
                    % (
                        entry["name"],
                        aws.helper.formatSize(done),
                        aws.helper.formatSize(total),
                        aws.helper.formatSpeed(speed),
                    )
                )
                sys.stdout.flush()
    if sys.stdout.isatty():
        sys.stdout.write("\n")

    checksum = aws.hashFile(dest, 1024 ** 2)["final"].hexdigest()
    expected = entry.get("checksum") or out.get("checksum")
    if expected and checksum != expected:
        logging.error("Checksum mismatch for %s", entry["name"])
        entry["status"] = "pending"
        entry["jobId"] = None
        try:
            os.remove(dest)
        except OSError:
            pass
        return

    entry["status"] = "done"
    entry["jobId"] = None
    logging.info("Finished %s", entry["name"])


def download_worker(
    download_queue,
    client,
    vault,
    destdir,
    state_lock,
    save_state_fn,
):
    """Worker that pulls (entry, state_file, state) from the queue, downloads, and persists state."""
    while True:
        item = download_queue.get()
        if item is _DOWNLOAD_QUEUE_SENTINEL:
            download_queue.task_done()
            break
        entry, state_file, state = item
        try:
            download_job(client, vault, entry, destdir)
        finally:
            with state_lock:
                save_state_fn(state_file, state)
        download_queue.task_done()


def main():
    parser = argparse.ArgumentParser(
        description="Iceshelf Retrieve - Download backups from Glacier",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument("vault", help="Name of the Glacier vault")
    parser.add_argument(
        "backup",
        nargs="*",
        metavar="BACKUP",
        help="One or more backup identifiers to retrieve",
    )
    parser.add_argument(
        "--database",
        help="Path to checksum.json database",
    )
    parser.add_argument("--all", action="store_true", default=False, help="Retrieve all backups")
    parser.add_argument(
        "--dest",
        default="retrieved",
        help="Destination directory for downloaded files",
    )
    parser.add_argument(
        "--threads", type=int, default=2, help="Number of parallel downloads"
    )
    parser.add_argument(
        "--wait",
        action="store_true",
        help="Wait (poll AWS) until inventory and archive jobs are ready instead of exiting; use with --wait-interval to tune poll interval.",
    )
    parser.add_argument(
        "--wait-interval",
        type=int,
        default=900,
        metavar="SECS",
        help="Seconds between polls when using --wait (default: 900)",
    )
    parser.add_argument("--logfile", metavar="FILE", help="Log to file instead of stdout")
    parser.add_argument(
        "--debug", action="store_true", default=False, help="Enable debug logging"
    )
    parser.add_argument(
        "--aws-region",
        dest="aws_region",
        metavar="REGION",
        help="AWS region (e.g. us-east-1). Required unless set in --aws-config file.",
    )
    parser.add_argument(
        "--aws-access-key-id",
        dest="aws_access_key_id",
        metavar="KEY",
        help="AWS access key ID. Use with --aws-secret-access-key, or set in --aws-config.",
    )
    parser.add_argument(
        "--aws-secret-access-key",
        dest="aws_secret_access_key",
        metavar="SECRET",
        help="AWS secret access key. Use with --aws-access-key-id, or set in --aws-config.",
    )
    parser.add_argument(
        "--aws-session-token",
        dest="aws_session_token",
        metavar="TOKEN",
        help="AWS session token (optional; for temporary credentials).",
    )
    parser.add_argument(
        "--aws-profile",
        dest="aws_profile",
        metavar="NAME",
        help="AWS profile name (alternative to access key/secret).",
    )
    parser.add_argument(
        "--aws-config",
        dest="aws_config",
        metavar="FILE",
        help="Path to YAML config file with region, access_key_id, secret_access_key, etc.",
    )
    parser.add_argument(
        "--aws-endpoint-url",
        dest="aws_endpoint_url",
        metavar="URL",
        help="Custom Glacier endpoint URL (optional; e.g. for testing).",
    )
    args = parser.parse_args()

    if not args.all and not args.backup:
        parser.error("Specify BACKUP or --all")

    loglevel = logging.DEBUG if args.debug else logging.INFO
    logformat = "%(asctime)s - %(levelname)s - %(message)s" if args.logfile else "%(message)s"
    if args.logfile:
        logging.basicConfig(filename=args.logfile, level=loglevel, format=logformat)
    else:
        logging.basicConfig(stream=sys.stdout, level=loglevel, format=logformat)

    db_path = args.database
    datadir = os.path.dirname(db_path) if db_path else args.dest
    os.makedirs(datadir, exist_ok=True)

    file_config = load_aws_config_file(args.aws_config)
    aws_config = merge_aws_config(file_config, args)
    client, err = create_glacier_client(aws_config)
    if err:
        logging.error("%s", err)
        return 1

    vault = args.vault

    try:
        inventory = ensure_inventory(
            client,
            vault,
            datadir,
            wait_until_ready=args.wait,
            poll_interval_secs=args.wait_interval,
        )
    except NoRegionError:
        logging.error(
            "AWS region is required. Use: --aws-region REGION (or set 'region' in config file)."
        )
        return 1
    except NoCredentialsError:
        logging.error(
            "AWS credentials required. Use: --aws-access-key-id and --aws-secret-access-key (or set in config file), or --aws-profile NAME."
        )
        return 1
    except ClientError as e:
        code = e.response.get("Error", {}).get("Code", "Unknown")
        logging.error("AWS error (%s). Check vault name, permissions, and network.", code)
        return 1

    if inventory is None:
        return 0

    backups_db = {}
    if args.all:
        # Build backup sets from inventory when database is unavailable
        for name, info in inventory.items():
            m = re.search(r"\d{8}-\d{6}-[0-9a-fA-F]{5}", name)
            if not m:
                logging.warning("Unable to determine backup id for %s", name)
                continue
            backups_db.setdefault(m.group(0), []).append(name)
        targets = sorted(backups_db.keys())
        if not targets:
            logging.error("No backups found in inventory")
            return 1
    else:
        if not os.path.exists(db_path):
            logging.error("Database %s not found", db_path)
            return 1
        with open(db_path, "r", encoding="utf-8") as f:
            db = json.load(f)
        if db.get("vault") and db.get("vault") != vault:
            logging.warning(
                "Database was created for vault %s but using %s", db.get("vault"), vault
            )
        backups_db = db.get("backups", {})
        missing = [b for b in args.backup if b not in backups_db]
        if missing:
            logging.error("Backup(s) not found: %s", ", ".join(missing))
            return 1
        targets = args.backup

    os.makedirs(args.dest, exist_ok=True)
    destdir = args.dest

    # Phase 1: For each backup, load state, sync with inventory, request all pending jobs.
    for backup in targets:
        files = backups_db[backup]
        state_file = os.path.join(datadir, f"retrieve-{backup}.json")
        state = load_state(state_file)

        # Update state with any new files
        for name in files:
            if name not in inventory:
                logging.error("File %s not found in vault inventory", name)
                continue
            if name not in state["files"]:
                info = inventory[name]
                state["files"][name] = {
                    "name": name,
                    "archiveId": info["archiveId"],
                    "size": info.get("size"),
                    "checksum": info.get("checksum"),
                    "jobId": None,
                    "status": "pending",
                }
        save_state(state_file, state)

        pending = [f for f in state["files"].values() if f["status"] != "done"]
        if not pending:
            logging.info("All files for %s already retrieved", backup)
            continue

        # After a crash, re-check entries that were "downloading"
        for entry in state["files"].values():
            if entry.get("status") == "downloading":
                entry["status"] = "requested"

        # Request jobs for all pending files (no workers yet)
        for entry in pending:
            if entry["jobId"] is None:
                request_job(client, vault, entry)
        save_state(state_file, state)

    # Phase 2: One producer over all backups; workers consume (entry, state_file, state).
    all_states = []
    for backup in targets:
        state_file = os.path.join(datadir, f"retrieve-{backup}.json")
        state = load_state(state_file)
        if any(e["status"] != "done" for e in state["files"].values()):
            all_states.append((state_file, state))

    if not all_states:
        logging.info("Done")
        return 0

    state_lock = threading.Lock()
    download_queue = Queue()
    workers = [
        threading.Thread(
            target=download_worker,
            args=(download_queue, client, vault, destdir, state_lock, save_state),
        )
        for _ in range(args.threads)
    ]
    for t in workers:
        t.start()

    # Producer: poll all in-flight jobs across all_states, enqueue ready as (entry, state_file, state)
    while True:
        to_check = []
        for state_file, state in all_states:
            for entry in state["files"].values():
                if (
                    entry["status"] not in ("done", "downloading")
                    and entry.get("jobId")
                ):
                    to_check.append((entry, state_file, state))

        if not to_check:
            break

        added = 0
        for entry, state_file, state in to_check:
            if entry["status"] == "ready" or check_job(client, vault, entry):
                with state_lock:
                    entry["status"] = "downloading"
                    save_state(state_file, state)
                download_queue.put((entry, state_file, state))
                added += 1

        if added == 0:
            if not args.wait:
                logging.info(
                    "No files are ready for download yet."
                    " Use --wait to have the tool wait until archives are ready."
                )
                for state_file, state in all_states:
                    with state_lock:
                        save_state(state_file, state)
                break
            interval_mins = args.wait_interval // 60
            logging.info(
                "Waiting for archives (polling every %d minutes)...", interval_mins
            )
            time.sleep(args.wait_interval)

    # Signal workers to exit and wait for in-flight downloads to finish
    for _ in range(args.threads):
        download_queue.put(_DOWNLOAD_QUEUE_SENTINEL)
    for t in workers:
        t.join()

    logging.info("Done")
    return 0


if __name__ == "__main__":
    sys.exit(main())
